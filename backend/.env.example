# MongoDB
MONGODB_URI=mongodb://localhost:27017/antologia

# Server
PORT=4000
BACKEND_URL=http://localhost:4000
NODE_ENV=development

# JWT (genera uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# SoundCloud API (desde https://soundcloud.com/you/apps)
SOUNDCLOUD_CLIENT_ID=your_client_id
SOUNDCLOUD_CLIENT_SECRET=your_client_secret

# Frontend URL (para CORS y redirect OAuth)
FRONTEND_URL=http://localhost:3000
